  4     v_name varchar(32);
  5     v_id_copy bison_pl_t.id%type;
  6     v_row bison_pl_t%rowtype;
  7     type rec_t is record(id int, name varchar(32));
  8     type rec_opt_t is record(id int not null := 1, name varchar(32) default 'opt');
  9     type refcur_t is ref cursor;
 10     type name_arr_t is varray(4) of varchar(32);
 11     type rec_tab_t is table of rec_t;
 12     v_rec rec_t;
 13     v_rec_opt rec_opt_t;
 14     v_names name_arr_t;
 15     v_recs rec_tab_t;
 16 begin
 17     v_id := bison_pl_func(1);
 18     v_id_copy := v_id;
 19     v_row.id := v_id;
 20     v_row.name := 'rowtype';
 21     v_rec.id := v_id;
 22     v_rec.name := 'record';
 23     v_rec_opt.id := v_required;
 24     v_rec_opt.name := 'record default';
 25     v_name := 'using';
 26 end;
 27 /

