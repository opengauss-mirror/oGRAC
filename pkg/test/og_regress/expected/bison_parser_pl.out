SQL> declare
  2     cursor c1 is select id from bison_pl_cursor_attr_t order by id;
  3     v_id int;
  4     v_count int;
  5 begin
  6     open c1;
  7     if c1%ISOPEN then
  8         insert into bison_pl_cursor_attr_log values('cursor_isopen', 1);
  9     end if;
 10     fetch c1 into v_id;
 11     if c1%FOUND then
 12         insert into bison_pl_cursor_attr_log values('cursor_found', v_id);
 13     end if;
 14     v_count := c1%ROWCOUNT;
 15     insert into bison_pl_cursor_attr_log values('cursor_rowcount', v_count);
 16     loop
 17         fetch c1 into v_id;
 18         exit when c1%NOTFOUND;
 19     end loop;
 20     insert into bison_pl_cursor_attr_log values('cursor_notfound', 1);
 21     close c1;
 22 end;
 23 /

PL/SQL procedure successfully completed.

