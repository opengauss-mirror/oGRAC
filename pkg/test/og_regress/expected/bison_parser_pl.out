SQL> declare
  2     type pushback_rec_t is record(id int, name varchar2(20));
  3     type id_tab_t is table of int index by binary_integer;
  4     v_rec pushback_rec_t;
  5     v_ids id_tab_t;
  6     v_id int := 0;
  7     v_name varchar2(20);
  8     cursor c_arg(p_min int, p_name varchar2 default 'PB') is
  9         select id, name from bison_pl_pushback_src where id >= p_min and name = p_name;
 10 begin
 11     v_ids(1) := 11;
 12     bison_pl_proc(v_ids(1));
 13
 14     open c_arg(p_min => 7, p_name => 'PB');
 15     fetch c_arg into v_id, v_name;
 16     close c_arg;
 17     v_rec.id := v_id;
 18     v_rec.name := v_name;
 19
 20     execute immediate 'select id, name from bison_pl_pushback_src where id = :1'
 21         into v_id, v_name using in v_rec.id;
 22
 23     insert into bison_pl_pushback_log values('assoc_type_lookahead', v_ids(1), 'ok');
 24     insert into bison_pl_pushback_log values('cursor_named_arg', v_rec.id, v_rec.name);
 25     insert into bison_pl_pushback_log values('execute_using', v_id, v_name);
 26 end;
 27 /

PL/SQL procedure successfully completed.

