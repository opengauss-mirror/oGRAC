SQL> create or replace procedure bison_pl_cursor_assign_proc is
  2     v_table varchar(130);
  3     v_part varchar(130);
  4     v_owner varchar(130);
  5 begin
  6     for item in (select owner, table_name, partition_name from bison_pl_cursor_loop_t) loop
  7         v_table := '"'||ITEM.TABLE_NAME||'"';
  8         v_part  := '"'||ITEM.PARTITION_NAME||'"';
  9         v_owner := '"'||ITEM.OWNER||'"';
 10         if v_table = '"TAB"' and v_part = '"P1"' and v_owner = '"USR"' then
