SQL> declare
  2     v_id int := 0;
  3     v_name varchar(32);
  4     type id_tab_t is table of int index by binary_integer;
  5     v_ids id_tab_t;
  6     rc sys_refcursor;
  7     cursor c is select id, name from bison_pl_t;
  8     cursor c_ids is select id from bison_pl_t;
  9     cursor c_empty is select id, name from bison_pl_t;
 10     cursor c_arg(p_min in int default 0) is select id, name from bison_pl_t where id >= p_min;
 11     v_crow c%rowtype;
 12 begin
 13     for r in (select id, name from bison_pl_t) loop
 14         v_id := r.id;
 15     end loop;
 16 
 17     for r in c_arg(0) loop
 18         v_name := r.name;
 19     end loop;
 20 
 21     for r in c_arg(coalesce(v_id, 0)) loop
 22         v_name := r.name;
 23     end loop;
 24 
 25     for r in c_empty loop
 26         v_name := r.name;
 27     end loop;
 28 
 29     open c;
 30     fetch c into v_crow;
 31     close c;
 32 
 33     open c;
 34     fetch c into v_id, v_name;
 35     close c;
 36 
 37     open c_ids;
 38     fetch c_ids bulk collect into v_ids limit 10;
 39     close c_ids;
 40 
 41     open c_empty;
 42     fetch c_empty into v_id, v_name;
 43     close c_empty;
 44 
 45     open c_arg(v_id);
 46     fetch c_arg into v_id, v_name;
 47     close c_arg;
 48 
 49     open c_arg(coalesce(v_id, 0));
 50     fetch c_arg into v_id, v_name;
 51     close c_arg;
 52 
 53     open rc for select id, name from bison_pl_t;
 54     close rc;
 55 
 56     open rc for 'select id, name from bison_pl_t where id = :1' using v_id;
 57     close rc;
 58 end;
 59 /

PL/SQL procedure successfully completed.

