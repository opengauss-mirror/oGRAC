SQL> create or replace trigger bison_pl_issue262_trg
  2 before insert on bison_pl_issue262_log
  3 for each row
  4 declare
  5     v$$ number := 0;
  6 begin
  7     /* outer
  8        /* inner */
  9        :new.not_exists := 1;
 10     */
 11     if :new.id is null then
 12         :new.id := 1;
 13     elsif :new.id < 0 then
 14         :new.id := 0;
 15     end if;
 16     while :new.id < 2 loop
 17         :new.id := :new.id + 1;
 18     end loop;
 19     case
 20         when :new.id = 2 then
 21             v$$ := :new.id;
 22             if v$$ = :new.id then
 23                 :new.action := 'p\' || to_char(:new.id) || '|' || ':new.id' || '|' || $$:old.id$$ || '|' || E'e\':old.id';
 24             else
 25                 :new.action := 'unexpected';
 26             end if;
 27         else
 28             :new.action := 'unexpected';
 29     end case;
 30 end;
 31 /

Succeed.

