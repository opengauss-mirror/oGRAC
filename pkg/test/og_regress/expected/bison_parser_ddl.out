SQL> -- ALTER TENANT requires environment-specific tablespaces, keep its bison syntax samples non-executed here.
SQL> create tenant bison_ddl_tenant tablespaces (bison_ddl_ts1) default tablespace bison_ddl_ts1;

OG-00780, The tablespace BISON_DDL_TS1 does not exist.
SQL> alter tenant bison_ddl_tenant add tablespaces (bison_ddl_ts2);

OG-01394, The tenant BISON_DDL_TENANT does not exist.
SQL> alter tenant bison_ddl_tenant default tablespace bison_ddl_ts2;

OG-01394, The tenant BISON_DDL_TENANT does not exist.
SQL> drop tenant if exists bison_ddl_tenant cascade;

Succeed.

