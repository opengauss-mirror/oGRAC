

SQL> -- 部门表
SQL> DROP TABLE IF EXISTS departments;

Succeed.

SQL> CREATE TABLE departments (
  2     dept_id INT PRIMARY KEY,
  3     dept_name VARCHAR(50),
  4     location VARCHAR(50)
  5 );

Succeed.

SQL> 
SQL> -- 员工表
SQL> DROP TABLE IF EXISTS employees;

Succeed.

SQL> CREATE TABLE employees (
  2     emp_id INT PRIMARY KEY,
  3     emp_name VARCHAR(50),
  4     dept_id INT,
  5     salary DECIMAL(10,2),
  6     hire_date DATE
  7 );

Succeed.

SQL> 
SQL> -- 订单表
SQL> DROP TABLE IF EXISTS orders;

Succeed.

SQL> CREATE TABLE orders (
  2     order_id INT PRIMARY KEY,
  3     cust_id INT,
  4     emp_id INT,
  5     amount DECIMAL(10,2),
  6     order_date DATE
  7 );

Succeed.

SQL> 
SQL> -- 客户表
SQL> DROP TABLE IF EXISTS customers;

Succeed.

SQL> CREATE TABLE customers (
  2     cust_id INT PRIMARY KEY,
  3     cust_name VARCHAR(50),
  4     city VARCHAR(50)
  5 );

Succeed.

SQL> 
SQL> -- 产品表
SQL> DROP TABLE IF EXISTS products;

Succeed.

SQL> CREATE TABLE products (
  2     prod_id INT PRIMARY KEY,
  3     prod_name VARCHAR(50),
  4     category VARCHAR(30),
  5     price DECIMAL(10,2)
  6 );

Succeed.

SQL> 
SQL> -- 销售表
SQL> DROP TABLE IF EXISTS sales;

Succeed.

SQL> CREATE TABLE sales (
  2     sale_id INT PRIMARY KEY,
  3     prod_id INT,
  4     emp_id INT,
  5     quantity INT,
  6     sale_date DATE
  7 );

Succeed.

