

SQL> drop table if exists t_insert02;

Succeed.

SQL> create table t_insert02(id int,name varchar(10));

Succeed.

SQL> insert into t_insert02 values (2,'小xiao明');

1 rows affected.

SQL> select id as new_id from t_insert02 where id = 2 and name = '小xiao明';

NEW_ID      
------------
2           

1 rows fetched.

SQL> insert into t_insert02 values (2,'小名明');

1 rows affected.

SQL> select id, name as new_name from t_insert02 where id = 2 and name = '小名明';

ID           NEW_NAME  
------------ ----------
2            小名明 

1 rows fetched.

SQL> drop table if exists t_insert02;
Succeed.




