

SQL> drop table if exists COMPANY;

Succeed.

SQL> CREATE TABLE COMPANY(
  2    ID INT PRIMARY KEY     NOT NULL,
  3    NAME           TEXT    NOT NULL,
  4    AGE            INT     NOT NULL,
  5    ADDRESS        CHAR(50),
  6    SALARY         REAL,
  7    JOIN_DATE      DATE
  8 );

Succeed.

