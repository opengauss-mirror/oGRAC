

SQL> drop table if exists t_insert02;

Succeed.

SQL> create table t_insert02(id int,name varchar(10));

Succeed.

SQL> insert into t_insert02 values (2,'小明');

1 rows affected.

SQL> select * from t_insert02 where id = 2;

ID           NAME      
------------ ----------
2            小明    

1 rows fetched.

SQL> insert into t_insert02 values (3,'小明');

1 rows affected.

SQL> select id from t_insert02 where id = 3;

ID          
------------
3           

1 rows fetched.

SQL> insert into t_insert02 values (4,'小明');

1 rows affected.

SQL> select id,name from t_insert02 where id = 4;

ID           NAME      
------------ ----------
4            小明    

1 rows fetched.

SQL> drop table if exists t_insert02;
Succeed.




