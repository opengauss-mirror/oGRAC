

SQL> drop table if exists all_datatype_tbl;

Succeed.

SQL> create table all_datatype_tbl(c_integer integer, c_varchar varchar(50));

Succeed.

SQL> insert into all_datatype_tbl values(1,'aaaaa');

1 rows affected.

SQL> insert into all_datatype_tbl values(2,'bbbbb');

1 rows affected.

SQL> insert into all_datatype_tbl values(3,'ccccccccc');

1 rows affected.

SQL> insert into all_datatype_tbl values(4,'ddddddddddddd');

1 rows affected.

SQL> insert into all_datatype_tbl values(5,'eeeeeeeeeee');

1 rows affected.

SQL> select * from all_datatype_tbl ;

C_INTEGER    C_VARCHAR                                         
------------ --------------------------------------------------
1            aaaaa                                             
2            bbbbb                                             
3            ccccccccc                                         
4            ddddddddddddd                                     
5            eeeeeeeeeee                                       

5 rows fetched.

SQL> update all_datatype_tbl t1 set (c_integer,c_varchar) = (select c_integer c1,c_varchar c2 from all_datatype_tbl t2 where t1.c_integer=t2.c_integer+1 and t1.c_varchar not like 'z');

5 rows affected.

SQL> select * from all_datatype_tbl order by 1;

C_INTEGER    C_VARCHAR                                         
------------ --------------------------------------------------
1            aaaaa                                             
2            bbbbb                                             
3            ccccccccc                                         
4            ddddddddddddd                                     
                                                               

5 rows fetched.

SQL> drop table all_datatype_tbl;

Succeed.

