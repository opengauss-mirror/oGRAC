

SQL> drop table if exists t_update01;

Succeed.

SQL> create table t_update01(id int,name varchar(10));

Succeed.

SQL> insert into t_update01 values(1,'hello'),(2,'world'),(3,'hello1');

3 rows affected.

SQL> update t_update01 as t set t.id = id + 1;

3 rows affected.

SQL> update t_update01 as t set t.name = upper(name);

3 rows affected.

SQL> select * from t_update01;

ID           NAME      
------------ ----------
2            HELLO     
3            WORLD     
4            HELLO1    

3 rows fetched.

SQL> drop table t_update01;

Succeed.

