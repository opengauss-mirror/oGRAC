

SQL> drop table if exists products15;

Succeed.

SQL> CREATE TABLE products15 (
  2     product_no integer PRIMARY KEY,
  3     name text,
  4     price numeric
  5 );

Succeed.

SQL> insert into  products15 values(110,'meat',22.5);

1 rows affected.

