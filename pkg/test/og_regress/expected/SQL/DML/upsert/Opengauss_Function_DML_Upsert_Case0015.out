

SQL> drop table if exists upsert1;

Succeed.

SQL> create table upsert1(id int primary key,age int,count int);

Succeed.

SQL> insert into upsert1 values (1,1,1),(4,4,4);

2 rows affected.

SQL> select * from upsert1;

ID           AGE          COUNT       
------------ ------------ ------------
1            1            1           
4            4            4           

2 rows fetched.

SQL> insert into upsert1 values(1,2,3),(1,2,3) ON DUPLICATE key update  age=2,count=3;

4 rows affected.

SQL> drop table upsert1;

Succeed.

