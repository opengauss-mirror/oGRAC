

SQL> drop table if exists upsert2;

Succeed.

SQL> create table upsert2(id int primary key,age int,count int);

Succeed.

SQL> insert into upsert2 values (1,1,1),(4,4,4);

2 rows affected.

SQL> select * from upsert2 order by id;

ID           AGE          COUNT       
------------ ------------ ------------
1            1            1           
4            4            4           

2 rows fetched.

SQL> 
SQL> insert into upsert2 values(2,1,1),(3,4,4) ON DUPLICATE key update age=1,count=1;

2 rows affected.

SQL> select * from upsert2 order by id;

ID           AGE          COUNT       
------------ ------------ ------------
1            1            1           
2            1            1           
3            4            4           
4            4            4           

4 rows fetched.

SQL> delete from upsert2;

4 rows affected.

SQL> insert into upsert2 values (1,1,1),(4,4,4);

2 rows affected.

SQL> 
SQL> insert into upsert2 values(2,1,1),(3,4,4) ON DUPLICATE key update age=4,count=4;

2 rows affected.

SQL> select * from upsert2 order by id;

ID           AGE          COUNT       
------------ ------------ ------------
1            1            1           
2            1            1           
3            4            4           
4            4            4           

4 rows fetched.

SQL> drop table upsert2;

Succeed.

