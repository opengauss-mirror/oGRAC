

SQL> drop table if exists products10;

Succeed.

SQL> CREATE TABLE products10 (
  2     product_no integer PRIMARY KEY,
  3     name text,
  4     price numeric
  5 );

Succeed.

SQL> insert into  products10 values(01,'grains',5.5);

1 rows affected.

SQL> select * from  products10;

PRODUCT_NO   NAME                                                             PRICE                                   
------------ ---------------------------------------------------------------- ----------------------------------------
1            grains                                                           5.5                                     

1 rows fetched.

SQL> insert into  products10 values(01,'grains',5.5) on DUPLICATE key update name='grains', price=5.5;

2 rows affected.

SQL> select * from  products10;

PRODUCT_NO   NAME                                                             PRICE                                   
------------ ---------------------------------------------------------------- ----------------------------------------
1            grains                                                           5.5                                     

1 rows fetched.

SQL> drop table products10;

Succeed.

