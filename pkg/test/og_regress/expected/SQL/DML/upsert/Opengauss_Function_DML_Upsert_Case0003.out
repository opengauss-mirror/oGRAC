

SQL> drop table if exists products;

Succeed.

SQL> CREATE TABLE products (
  2     product_no integer PRIMARY KEY,
  3     name text,
  4     price numeric
  5 );

Succeed.

SQL> insert into  products values(01,'grains',5.5),(02,'veggies',6.5);

2 rows affected.

SQL> select * from products;

PRODUCT_NO   NAME                                                             PRICE                                   
------------ ---------------------------------------------------------------- ----------------------------------------
1            grains                                                           5.5                                     
2            veggies                                                          6.5                                     

2 rows fetched.

SQL> drop table products;

Succeed.

