SQL> create table t_mergeinto_15_02(product_id integer,product_name varchar2(60),
  2 category varchar2(60));

Succeed.

SQL> insert into t_mergeinto_15_02 values (1502, 'olympus camera', 'electrncs');

1 rows affected.

SQL> insert into t_mergeinto_15_02 values (1601, 'lamaze', 'toys');

1 rows affected.

SQL> insert into t_mergeinto_15_02 values (1666, 'harry potter', 'toys');

1 rows affected.

SQL> insert into t_mergeinto_15_02 values (1700, 'wait interface', 'books');

1 rows affected.

SQL> create view v_mergeinto_15 as select * from t_mergeinto_15_02;

Succeed.

SQL> merge into t_mergeinto_15_01  t1   using v_mergeinto_15
  2 on (t1.product_id = v_mergeinto_15.product_id)
  3 when matched then
  4   update set t1.product_name = v_mergeinto_15.product_name,
  5   t1.category = v_mergeinto_15.category  where t1.product_name != 'play gym'
  6 when not matched then
  7   insert values (v_mergeinto_15.product_id, v_mergeinto_15.product_name,
  8   v_mergeinto_15.category)
  9    where v_mergeinto_15.category = 'books';

4 rows affected.

