SQL> create table t_mergeinto_26_02(product_id integer,product_name varchar2(60),
  2 category varchar2(60));

Succeed.

SQL> insert into t_mergeinto_26_02 values (1502, 'olympus camera', 'electrncs');

1 rows affected.

SQL> insert into t_mergeinto_26_02 values (1601, 'lamaze', 'toys');

1 rows affected.

SQL> insert into t_mergeinto_26_02 values (1666, 'harry potter', 'toys');

1 rows affected.

SQL> insert into t_mergeinto_26_02 values (1700, 'wait interface', 'books');

1 rows affected.

SQL> merge into t_mergeinto_26_01 t1  using t_mergeinto_26_02 t2
  2 on (t1.product_name = t2.product_name)
  3 when not matched then
  4   insert values (t2.product_id, t2.product_name, t2.category)
  5   where t2.category = 'books'
  6 when matched then
  7   update set t1.product_id = t2.product_id, t1.category = t2.category
  8   where t1.product_name != 'play gym';

3 rows affected.

