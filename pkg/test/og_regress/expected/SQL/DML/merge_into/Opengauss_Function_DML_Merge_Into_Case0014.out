SQL> merge into t_mergeinto_14_03 t3   using t_mergeinto_14_04 t4
  2  on (t3.product_id = t4.product_id)
  3 when matched then
  4   update set t3.product_name = t4.product_name, t3.category = t4.category
  5   where t3.product_name != 'play gym'
  6 when not matched then
  7   insert values (t4.product_id, t4.product_name, t4.category)
  8   where t4.category = 'books';

4 rows affected.

