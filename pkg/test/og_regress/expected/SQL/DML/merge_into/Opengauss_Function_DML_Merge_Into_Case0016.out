

SQL> drop table if exists t_mergeinto_16_01;

Succeed.

SQL> drop table if exists t_mergeinto_16_02;

Succeed.

SQL> create table t_mergeinto_16_01(product_id integer,product_name varchar2(60),
  2 category varchar2(60));

Succeed.

SQL> insert into t_mergeinto_16_01 values (1501, 'vivitar 35mm', 'electrncs');

1 rows affected.

