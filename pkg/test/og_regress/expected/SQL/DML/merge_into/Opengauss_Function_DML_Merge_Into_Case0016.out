SQL> create table t_mergeinto_16_02(product_id integer,product_name varchar2(60),
  2 category varchar2(60));

Succeed.

SQL> insert into t_mergeinto_16_02 values (1502, 'olympus camera', 'electrncs');

1 rows affected.

SQL> insert into t_mergeinto_16_02 values (1601, 'lamaze', 'toys');

1 rows affected.

SQL> insert into t_mergeinto_16_02 values (1666, 'harry potter', 'toys');

1 rows affected.

SQL> insert into t_mergeinto_16_02 values (1700, 'wait interface', 'books');

1 rows affected.

SQL> merge into t_mergeinto_16_01 t1  using  (select * from  t_mergeinto_16_02 t2
  2  where  t2.category = (select category from t_mergeinto_16_02
  3    where product_name='lamaze'))  t2
  4    on (t1.product_id = t2.product_id)
  5 when matched then
  6   update set t1.product_name = t2.product_name, t1.category = t2.category
  7   where t1.product_name != 'play gym'
  8 when not matched then
  9   insert values (t2.product_id, t2.product_name, t2.category)
 10   where t2.category = 'books';

2 rows affected.

