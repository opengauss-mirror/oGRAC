

SQL> drop table if exists t_mergeinto_11_01;

Succeed.

SQL> drop table if exists t_mergeinto_11_02;

Succeed.

SQL> create table t_mergeinto_11_01(product_id integer,product_name varchar2(60),
  2 category varchar2(60));

