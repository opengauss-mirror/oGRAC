SQL> create table t_mergeinto_11_02(product_id integer,product_name varchar2(60),
  2 category varchar2(60));

Succeed.

SQL> insert into t_mergeinto_11_02 values (1502, 'olympus camera', 'electrncs');

1 rows affected.

SQL> insert into t_mergeinto_11_02 values (1601, 'lamaze', 'toys');

1 rows affected.

SQL> insert into t_mergeinto_11_02 values (1666, 'harry potter', 'toys');

1 rows affected.

SQL> insert into t_mergeinto_11_02 values (1700, 'wait interface', 'books');

1 rows affected.

SQL> merge into t_mergeinto_11_01    using t_mergeinto_11_02
  2 on (t_mergeinto_11_01.product_id = t_mergeinto_11_02.product_id)
  3 when matched then
  4   update set t_mergeinto_11_01.product_name = t_mergeinto_11_02.product_name,
  5    t_mergeinto_11_01.category = t_mergeinto_11_02.category
  6    where t_mergeinto_11_01.product_name != 'play gym'
  7 when not matched then
  8   insert values (t_mergeinto_11_02.product_id, t_mergeinto_11_02.product_name,
  9   t_mergeinto_11_02.category) where t_mergeinto_11_02.category = 'books';

4 rows affected.

