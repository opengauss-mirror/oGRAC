SQL> merge into t_mergeinto_27_01 t1  using t_mergeinto_27_02 t2
  2 on (t1.product_name = t2.product_name)
  3 when matched then
  4   update set t1.product_id = t2.product_id, t1.category = t2.category
  5   where t1.product_name != 'play gym';

2 rows affected.

