

SQL> drop TABLE if exists t_dml0011;

Succeed.

SQL> CREATE TABLE t_dml0011 (
  2     emp_id SERIAL PRIMARY KEY,
  3     emp_name VARCHAR(100),
  4     department_id INT,
  5     salary NUMERIC
  6 );

Succeed.

SQL> 
