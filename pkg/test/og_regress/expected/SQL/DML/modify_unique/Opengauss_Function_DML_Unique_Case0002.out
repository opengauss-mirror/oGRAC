

SQL> drop table if exists tab2;

Succeed.

SQL> create table tab2(
  2 c_id int, c_integer integer,
  3 c_real real,c_float float, c_cdouble binary_integer,
  4 c_decimal decimal(38),c_decimal1 decimal,
  5 c_number number(38),c_number1 number,c_number2 number(20,10),c_numeric numeric(38),
  6 c_char char(50) default null, c_varchar varchar(20), c_varchar2 varchar2(4000),
  7 c_clob clob,
  8 c_raw raw(20),c_blob blob
  9 );

Succeed.

SQL> alter table tab2  add constraint un2 unique (c_real);

Succeed.

SQL> drop table if exists tab2;

Succeed.

