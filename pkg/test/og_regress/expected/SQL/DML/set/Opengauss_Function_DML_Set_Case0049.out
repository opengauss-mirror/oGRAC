

SQL> drop table if exists student;

Succeed.

SQL>                                       create table student(id int, name char(20));

Succeed.

SQL>                                       drop index if exists unique_id;

Succeed.

SQL>                                       CREATE INDEX unique_id on student(id);

Succeed.

SQL> 
