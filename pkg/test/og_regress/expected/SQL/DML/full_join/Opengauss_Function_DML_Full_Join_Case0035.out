SQL> select
  2     *
  3 from
  4     (
  5     select
  6         alias2.w_name alias6 ,
  7         alias2.w_tax alias7,
  8         mod(t_join_0035_04.w_id,
  9         t_join_0035_04.w_ytd + 10) alias8
 10     from
 11         t_join_0035_01 alias1
 12     full join t_join_0035_02 alias2 on
 13         alias1.w_zip = alias2.w_street_2,
 14         t_join_0035_04)alias9
