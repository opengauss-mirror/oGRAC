

SQL> drop table if exists t_delete03;

Succeed.

SQL> create table t_delete03(id int,name varchar(10));

Succeed.

SQL> insert into t_delete03 values (1,'小明');

1 rows affected.

SQL> insert into t_delete03 values (2,'小李');

1 rows affected.

SQL> drop table if exists t_delete04;

Succeed.

SQL> create table t_delete04(id int,t_num varchar(10));

Succeed.

SQL> insert into t_delete04 values (1,'小明');

1 rows affected.

SQL> insert into t_delete04 values (2,'小李');

1 rows affected.

SQL> delete from t_delete03 where id = 1 and exists (
  2   select 1 from t_delete04 where t_delete03.id = t_delete04.id
  3 );

1 rows affected.

SQL> select * from t_delete03 order by id;

ID           NAME      
------------ ----------
2            小李    

1 rows fetched.

SQL> drop table t_delete03;

Succeed.

