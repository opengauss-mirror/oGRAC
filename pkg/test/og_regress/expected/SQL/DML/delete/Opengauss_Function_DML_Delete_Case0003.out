

SQL> drop table if exists t_delete02;

Succeed.

SQL> create table t_delete02(id int,name varchar(10));

Succeed.

SQL> insert into t_delete02 values (1,'小明');

1 rows affected.

SQL> insert into t_delete02 values (2,'小明');

1 rows affected.

SQL> insert into t_delete02 values (3,'小明');

1 rows affected.

SQL> insert into t_delete02 values (4,'小李');

1 rows affected.

SQL> insert into t_delete02 values (5,'小李');

1 rows affected.

SQL> insert into t_delete02 values (6,'小李');

1 rows affected.

SQL> insert into t_delete02 values (7,'小红');

1 rows affected.

SQL> insert into t_delete02 values (8,'小红');

1 rows affected.

SQL> delete from t_delete02 where exists (
  2   select 1 from t_delete02 b where t_delete02.id < b.id and t_delete02.name = b.name
  3 );

5 rows affected.

SQL> select * from t_delete02 order by id;

ID           NAME      
------------ ----------
